general {
    colors = true
    interval = 1
    output_format = "i3bar"
    
    # Your custom color palette
    color_good = "#FAD1E6"      # Soft Pink (Regular/Intermediate)
    color_degraded = "#FAD1E6"  # Keeping it pink for intermediate
    color_bad = "#FF00FF"       # Magenta (Extreme Cases)
}

order += "wireless _first_"
order += "cpu_usage"
order += "cpu_temperature 0"
order += "memory"
order += "volume master"
order += "read_file kbd"
order += "tztime local"

wireless _first_ {
    # Restored %quality (connection strength) and %ip (IP address)
    format_up = "  %essid (%quality) %ip "
    format_down = "  down "
}

cpu_usage {
    format = " CPU: %usage "
    degraded_threshold = 70
    max_threshold = 85
}

cpu_temperature 0 {
    format = " %degrees°C "
    path = "/sys/class/thermal/thermal_zone6/temp"
    max_threshold = 75
}

memory {
    format = " RAM: %used "
    threshold_degraded = "15%" 
    threshold_critical = "5%"
}

volume master {
    format = " VOL: %volume "
    format_muted = " VOL: MUTED "
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}

tztime local {
    format = " %Y-%m-%d %H:%M:%S "
    timezone = "Etc/GMT+4"
}
